        "type": "http"
      },
      "http": {
        "method": "POST",
        "url": "https://api.honeybadger.io/v1/notices",
        "body": {
          "type": "json",
          "data": "{}"
        },
        "auth": {
          "type": "apikey",
          "key": "X-API-Key",
          "value": "{{X-API-Key}}",
          "placement": "header"
        }
      },
      "docs": "Report an exception"
    },
